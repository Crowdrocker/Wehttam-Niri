
/* wehttamsnaps-yad — KeyHints cyberpunk styling */
.yad-list-view,
.yad-list-view * {
    background-color: #06060f;
    color: #c8d0e8;
    font-family: "JetBrains Mono", monospace;
    font-size: 10pt;
}
.yad-list-view:selected,
.yad-list-view:selected * {
    background-color: rgba(0,255,209,0.12);
    color: #00ffd1;
}
.yad-dialog {
    background-color: #06060f;
}
headerbar,
headerbar * {
    background-color: #0a0a1c;
    color: #c8d0e8;
}
