// ═══════════════════════════════════════════════════════════════════════════════
// WEHTTAMSNAPS NIRI - STARTUP CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════
// Applications to start automatically when Niri launches
// Author: Matthew (WehttamSnaps)
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// SPAWN AT STARTUP
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Sound System ───
// Play J.A.R.V.I.S. startup sound
spawn-at-startup "bash" "-c" "sound-system startup"

spawn-at-startup "qs" "-c" "noctalia-shell"

// ─── Wallpaper ───
spawn-sh-at-startup "swww-daemon" // Wallpaper daemon

// ─── Status Bar ───
// Uncomment if using Waybar
// spawn-at-startup "waybar"

// ─── Polkit Authentication Agent ───
spawn-at-startup "/usr/lib/polkit-kde-authentication-agent-1"

// ─── Notification Daemon ───
//spawn-at-startup "mako"
// Or use dunst:
spawn-at-startup "dunst"

// ─── Clipboard Manager ───
spawn-at-startup "wl-paste" "--type" "text" "--watch" "cliphist" "store"
spawn-at-startup "wl-paste" "--type" "image" "--watch" "cliphist" "store"

// ─── Night Light (if using wlsunset) ───
// spawn-at-startup "wlsunset" "-l" "37.7749" "-L" "-122.4194"  // San Francisco coords

// ─── Input Method (if needed) ───
// spawn-at-startup "fcitx5" "-d"

// ─── WehttamSnaps Welcome App ───
spawn-at-startup "bash" "-c" "sleep 2 && python3 ~/.config/wehttamsnaps/scripts/wehttamsnaps-welcome.py"

// ─── GAMING: Auto-start Steam Minimized (optional) ───
// spawn-at-startup "steam" "-silent"

// ─── COMMS: Auto-start Discord Minimized (optional) ───
// spawn-at-startup "discord" "--start-minimized"

//spawn-at-startup "bash" "-c" "sound-system startup" ═══════════════════════════════════════════════════════════════════════════════
// ENVIRONMENT SETUP AT STARTUP
// ═══════════════════════════════════════════════════════════════════════════════

// Set keyboard repeat rate
spawn-at-startup "xkbset" "repeat" "rate" "300" "50"

// Set DPMS settings (display power management)
//spawn-at-startup "xset" "s" "off" "dpms" "0" "0" "1200"  // Screen off after 20 min


// ╭─────────────────────────────── AUTOSTART ────────────────────────────────────────╮
spawn-at-startup "xwayland-satellite"

// J.A.R.V.I.S. startup with notification
//spawn-at-startup "sh" "-c" "sound-system startup && notify-send 'J.A.R.V.I.S.' 'Systems online. Welcome back, Matthew.' -i audio-speakers"
// Config watcher for real-time validation
spawn-at-startup "bash" "-c" "~/.config/wehttamsnaps/scripts/config-watcher.sh start &"
// save list of currently installed programs

spawn-at-startup "~/.config/wehttamsnaps/scripts/save-program-list.sh"

// Auto-setup audio routing on login
//spawn-at-startup "bash" "-c" "sleep 5 && ~/.config/wehttamsnaps/scripts/audio-routing.sh gaming"
spawn-sh-at-startup "niriswitcher"
spawn-at-startup "udiskie" "--tray"  // Auto-mount USB devices
spawn-at-startup "blueman-applet"  // Bluetooth tray
spawn-at-startup "nm-applet"  // Network manager tray
spawn-at-startup "sh" "-c" "swayidle -w timeout 600 'swaylock' timeout 900 'niri msg action power-off-monitors' resume 'niri msg action power-on-monitors' before-sleep 'swaylock'"
// ╰──────────────────────────────────────────────────────────────────────────────────╯

// ═══════════════════════════════════════════════════════════════════════════════
// END OF STARTUP CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════
