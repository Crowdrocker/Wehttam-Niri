#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEHTTAMSNAPS ADAPTIVE SOUND SYSTEM v2.0
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Automatically switches between J.A.R.V.I.S. and iDroid voices based on context
# Author: Matthew (WehttamSnaps)
#
# FEATURES:
#   • Adaptive mode switching (JARVIS for productivity, iDroid for gaming)
#   • App launch sounds for all your keybinds
#   • Audio feedback for system events
#   • Gaming mode toggle
#
# SOUND FILES LOCATION:
#   /usr/share/wehttamsnaps/sounds/jarvis/  (J.A.R.V.I.S. voice)
#   /usr/share/wehttamsnaps/sounds/idroid/  (iDroid voice)
#
# USAGE:
#   sound-system <command> [args]
#   sound-system status          - Show current mode
#   sound-system list            - List all available sounds
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

set -u
# Note: -e and -o pipefail intentionally removed — missing sound files must not crash the script

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

SOUND_BASE="/usr/share/wehttamsnaps/sounds"
STATE_FILE="$HOME/.cache/wehttamsnaps/sound-mode.state"
WORKSPACE_FILE="$HOME/.cache/wehttamsnaps/current-workspace.state"
VOLUME=70

# Ensure directories exist
mkdir -p "$(dirname "$STATE_FILE")"
mkdir -p "$SOUND_BASE"/{jarvis,idroid}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ═══════════════════════════════════════════════════════════════════════════════
# SOUND MODE MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════

get_current_mode() {
    if [[ -f "$STATE_FILE" ]]; then
        cat "$STATE_FILE"
    else
        echo "jarvis"
    fi
}

set_mode() {
    local mode="$1"
    echo "$mode" > "$STATE_FILE"
    echo -e "${CYAN}🔊 Sound mode:${NC} ${GREEN}$mode${NC}"
}

get_current_workspace() {
    # Try to get workspace from Niri
    if command -v niri &> /dev/null; then
        niri msg workspaces 2>/dev/null | grep -oP 'Workspace \K\d+' | head -1 || echo "1"
    elif [[ -f "$WORKSPACE_FILE" ]]; then
        cat "$WORKSPACE_FILE"
    else
        echo "1"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# AUTO-DETECT MODE BASED ON CONTEXT
# ═══════════════════════════════════════════════════════════════════════════════

auto_detect_mode() {
    local workspace
    workspace=$(get_current_workspace)

    # Gaming workspaces (2, 6, 7) -> iDroid
    if [[ "$workspace" =~ ^(2|6|7)$ ]]; then
        echo "idroid"
        return
    fi

    # Photography workspace (3) -> J.A.R.V.I.S.
    if [[ "$workspace" == "3" ]]; then
        echo "jarvis"
        return
    fi

    # Check if gaming mode is active
    if [[ -f "$HOME/.cache/wehttamsnaps/gaming-mode.active" ]]; then
        echo "idroid"
        return
    fi

    # Default to J.A.R.V.I.S.
    echo "jarvis"
}

# ═══════════════════════════════════════════════════════════════════════════════
# PLAY SOUND FUNCTION
# ═══════════════════════════════════════════════════════════════════════════════

play_sound() {
    local sound_name="$1"
    local force_mode="${2:-}"

    # Determine which mode to use
    local mode
    if [[ -n "$force_mode" ]]; then
        mode="$force_mode"
    else
        mode=$(auto_detect_mode)
    fi

    # Try .mp3 first, then .wav
    local sound_path=""
    for ext in mp3 wav; do
        local path="$SOUND_BASE/$mode/$sound_name.$ext"
        if [[ -f "$path" ]]; then
            sound_path="$path"
            break
        fi
    done

    # Fallback to other mode if sound doesn't exist
    if [[ -z "$sound_path" ]]; then
        local alt_mode
        [[ "$mode" == "jarvis" ]] && alt_mode="idroid" || alt_mode="jarvis"
        for ext in mp3 wav; do
            local path="$SOUND_BASE/$alt_mode/$sound_name.$ext"
            if [[ -f "$path" ]]; then
                sound_path="$path"
                break
            fi
        done
    fi

    # Play sound if exists
    if [[ -n "$sound_path" && -f "$sound_path" ]]; then
        if command -v paplay &> /dev/null; then
            paplay --volume=$((VOLUME * 655)) "$sound_path" &
        elif command -v mpv &> /dev/null; then
            mpv --no-terminal --volume="$VOLUME" "$sound_path" &
        elif command -v ffplay &> /dev/null; then
            ffplay -nodisp -autoexit -volume "$VOLUME" "$sound_path" &>/dev/null &
        fi
    else
        echo -e "${YELLOW}⚠${NC} Sound not found: $sound_name" >&2
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# AUDIO CONTROLS
# ═══════════════════════════════════════════════════════════════════════════════

audio_mute_toggle() {
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    if wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q "MUTED"; then
        play_sound "jarvis-audio-mute"
    else
        play_sound "jarvis-audio-unmute"
    fi
}

audio_volume_up() {
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    play_sound "jarvis-volume-up"
}

audio_volume_down() {
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    play_sound "jarvis-volume-down"
}

mic_mute_toggle() {
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    if wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q "MUTED"; then
        play_sound "jarvis-mic-mute"
    else
        play_sound "jarvis-mic-unmute"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# MODE MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════

gaming_mode_toggle() {
    local gaming_flag="$HOME/.cache/wehttamsnaps/gaming-mode.active"

    if [[ -f "$gaming_flag" ]]; then
        # Disable gaming mode
        rm "$gaming_flag"
        set_mode "idroid"
        play_sound "idroid-gamemode-off" "idroid"
        notify-send "Gaming Mode" "Disabled - J.A.R.V.I.S. active" -i input-gaming 2>/dev/null || true
    else
        # Enable gaming mode
        touch "$gaming_flag"
        set_mode "idroid"
        play_sound "idroid-gamemode-on" "idroid"
        notify-send "Gaming Mode" "Enabled - iDroid active" -i input-gaming 2>/dev/null || true
    fi
}

workspace_switch() {
    local workspace="$1"
    echo "$workspace" > "$WORKSPACE_FILE"

    # Auto-detect and switch mode
    local new_mode
    new_mode=$(auto_detect_mode)
    set_mode "$new_mode"

    play_sound "jarvis-workspace-switch"
}

# ═══════════════════════════════════════════════════════════════════════════════
# SYSTEM EVENTS
# ═══════════════════════════════════════════════════════════════════════════════

system_startup() {
    set_mode "jarvis"
    # Time-based greeting
    local hour
    hour=$(date +%H)
    if (( hour >= 5 && hour < 12 )); then
        play_sound "jarvis-morning" "jarvis"
    elif (( hour >= 12 && hour < 17 )); then
        play_sound "jarvis-afternoon" "jarvis"
    else
        play_sound "jarvis-evening" "jarvis"
    fi
    play_sound "jarvis-startup" "idroid"
}

system_shutdown() {
    play_sound "jarvis-shutdown" "jarvis"
}

notification() {
    play_sound "jarvis-notification"
}

screenshot_taken() {
    play_sound "jarvis-screenshot"
}

window_close() {
    play_sound "jarvis-window-close"
}

steam_launch() {
    set_mode "idroid"
    play_sound "idroid-steam-launch" "idroid"
}

photo_export() {
    play_sound "jarvis-photo-export" "jarvis"
}

config_reload() {
    play_sound "jarvis-reload" "jarvis"
}

