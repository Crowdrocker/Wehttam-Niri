# ═══════════════════════════════════════════════════════════════════════════════
# TESTING & PREVIEW
# ═══════════════════════════════════════════════════════════════════════════════

test_all_sounds() {
    echo -e "${CYAN}🔊 Testing all sounds...${NC}\n"

    for mode in jarvis idroid; do
        echo -e "${BLUE}━━━ $mode sounds ━━━${NC}"

        if [[ -d "$SOUND_BASE/$mode" ]]; then
            local count=0
            for sound in "$SOUND_BASE/$mode"/*.{mp3,wav} 2>/dev/null; do
                if [[ -f "$sound" ]]; then
                    local name
                    name=$(basename "$sound" | sed 's/\.[^.]*$//')
                    echo -e "  ${GREEN}▶${NC} Playing: $name"
                    if command -v paplay &> /dev/null; then
                        paplay "$sound"
                    fi
                    sleep 0.3
                    ((count++))
                fi
            done

            if [[ $count -eq 0 ]]; then
                echo -e "  ${YELLOW}⚠${NC} No sounds found"
            else
                echo -e "  ${GREEN}✓${NC} $count sounds tested"
            fi
        else
            echo -e "  ${RED}✗${NC} Directory not found: $SOUND_BASE/$mode"
        fi
        echo ""
    done
}

preview_sound() {
    local sound_name="$1"
    local mode="${2:-jarvis}"

    for ext in mp3 wav; do
        local sound_path="$SOUND_BASE/$mode/$sound_name.$ext"
        if [[ -f "$sound_path" ]]; then
            echo -e "${GREEN}▶${NC} Playing: $mode/$sound_name.$ext"
            paplay "$sound_path"
            return 0
        fi
    done

    echo -e "${RED}✗${NC} Sound not found: $mode/$sound_name"
    return 1
}

list_sounds() {
    echo -e "${CYAN}📁 Available sounds:${NC}\n"

    for mode in jarvis idroid; do
        echo -e "${BLUE}━━━ $mode ━━━${NC}"

        if [[ -d "$SOUND_BASE/$mode" ]]; then
            local count=0
            for sound in "$SOUND_BASE/$mode"/*.{mp3,wav} 2>/dev/null; do
                if [[ -f "$sound" ]]; then
                    local name
                    name=$(basename "$sound" | sed 's/\.[^.]*$//')
                    echo -e "  ${GREEN}•${NC} $name"
                    ((count++))
                fi
            done

            if [[ $count -eq 0 ]]; then
                echo -e "  ${YELLOW}⚠${NC} No sounds found"
            else
                echo -e "  ${CYAN}Total: $count sounds${NC}"
            fi
        else
            echo -e "  ${RED}✗${NC} Directory not found"
        fi
        echo ""
    done
}

# ═══════════════════════════════════════════════════════════════════════════════
