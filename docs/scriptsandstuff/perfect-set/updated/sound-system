#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEHTTAMSNAPS ADAPTIVE SOUND SYSTEM v3.0 (CLEAN EDITION)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SOUND_BASE="/usr/share/wehttamsnaps/sounds"
STATE_FILE="$HOME/.cache/wehttamsnaps/sound-mode.state"
SILENT_FLAG="$HOME/.cache/wehttamsnaps/silent.active"

mkdir -p "$(dirname "$STATE_FILE")"

play_sound() {
    local sound_name="$1"
    local mode
    mode=$(cat "$STATE_FILE" 2>/dev/null || echo "jarvis")

    [[ -f "$SILENT_FLAG" ]] && return 0

    # Logic: Look for exact file, then with jarvis- prefix, then fallback to jarvis folder
    if [[ -f "$SOUND_BASE/$mode/$sound_name.mp3" ]]; then
        paplay "$SOUND_BASE/$mode/$sound_name.mp3" &
    elif [[ -f "$SOUND_BASE/$mode/jarvis-$sound_name.mp3" ]]; then
        paplay "$SOUND_BASE/$mode/jarvis-$sound_name.mp3" &
    elif [[ -f "$SOUND_BASE/jarvis/$sound_name.mp3" ]]; then
        paplay "$SOUND_BASE/jarvis/$sound_name.mp3" &
    elif [[ -f "$SOUND_BASE/jarvis/jarvis-$sound_name.mp3" ]]; then
        paplay "$SOUND_BASE/jarvis/jarvis-$sound_name.mp3" &
    fi
}

case "$1" in
    # --- CORE PROTOCOLS ---
    startup)        play_sound "jarvis-startup" ;;
    shutdown)       play_sound "jarvis-shutdown" ;;
    reload)         play_sound "jarvis-reload" ;;
    lock|locking-screen) play_sound "jarvis-lock" ;;
    greeting)       play_sound "jarvis-greeting" ;;

    # --- APP LAUNCHERS ---
    launch-brave)   play_sound "jarvis-launch-brave" ;;
    launch-chrome)  play_sound "jarvis-launch-chrome" ;;
    launch-discord) play_sound "jarvis-launch-discord" ;;
    launch-editor)  play_sound "jarvis-launch-editor" ;;
    launch-firefox) play_sound "jarvis-launch-firefox" ;;
    launch-gimp)    play_sound "jarvis-launch-gimp" ;;
    launch-obs)     play_sound "jarvis-launch-obs" ;;
    launch-spotify) play_sound "jarvis-launch-spotify" ;;
    launch-steam)   play_sound "jarvis-steam-launch" ;;
    open-files)     play_sound "jarvis-open-files" ;;
    open-terminal)  play_sound "jarvis-open-terminal" ;;

    # --- AUDIO & UTILITY ---
    volume-up)      play_sound "jarvis-volume-up" ;;
    volume-down)    play_sound "jarvis-volume-down" ;;
    mute)           play_sound "jarvis-audio-mute" ;;
    unmute)         play_sound "jarvis-audio-unmute" ;;
    screenshot)     play_sound "jarvis-screenshot" ;;
    confirm)        play_sound "jarvis-confirm" ;;
    workspace)      play_sound "jarvis-workspace-switch" ;;

    # --- MODE CONTROLS ---
    mode)           echo "${2:-jarvis}" > "$STATE_FILE" ;;
    silent-toggle)
        if [[ -f "$SILENT_FLAG" ]]; then
            rm "$SILENT_FLAG" && play_sound "jarvis-confirm"
        else
            play_sound "jarvis-shutdown" && touch "$SILENT_FLAG"
        fi
        ;;

    # --- LISTING & PREVIEW ---
    list|ls)
        echo "--- J.A.R.V.I.S. LIBRARY ---"
        ls "$SOUND_BASE/jarvis"/*.mp3 | sed 's|.*/||' | sed 's|^|  • |'
        ;;
    preview)        play_sound "$2" ;;
    status)         echo "Active Mode: $(cat "$STATE_FILE")" ;;
    *)              echo "Usage: sound-system {startup|reload|launch-brave|preview <file>}" ;;
esac
