// ╚══════════════════════════════════════════════════════════════════════════════╝
//
// This is the main entry point for Niri configuration.
// All modular configs are sourced from the conf.d/ directory.
//
// Configuration Structure:
// ├── 00-base.kdl       - Environment, input, layout settings
// ├── 10-keybinds.kdl   - Keyboard shortcuts
// ├── 20-window-rules.kdl - Window rules for applications
// ├── 30-workspaces.kdl - Workspace definitions
// ├── 40-startup.kdl    - Autostart applications
// └── 50-animations.kdl - Animation settings

// ═══════════════════════════════════════════════════════════════════════════════
// INCLUDE MODULAR CONFIGURATIONS
// ═══════════════════════════════════════════════════════════════════════════════

// The following includes are processed in order
// Each file handles a specific aspect of the configuration

// Base settings (environment, input, layout)
include "conf.d/00-base.kdl"

// Keyboard shortcuts
include "conf.d/10-keybinds.kdl"

// Window rules for applications
include "conf.d/20-window-rules.kdl"

// Workspace definitions
include "conf.d/30-workspaces.kdl"

// Autostart applications
include "conf.d/40-startup.kdl"

// Animation settings
include "conf.d/50-animations.kdl"
