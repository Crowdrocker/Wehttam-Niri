// ═══════════════════════════════════════════════════════════════════════════════
// COMMUNICATION
// ═══════════════════════════════════════════════════════════════════════════════

// Discord - Workspace 7 (Communication)
window-rule {
    match app-id="discord"
    open-on-workspace "communication"
}

// Telegram
window-rule {
    match app-id="telegramdesktop"
    open-on-workspace "communication"
}

// Slack
window-rule {
    match app-id="slack"
    open-on-workspace "communication"
}

// ═══════════════════════════════════════════════════════════════════════════════
// MUSIC
// ═══════════════════════════════════════════════════════════════════════════════

// Spotify - Workspace 8 (Music)
window-rule {
    match app-id="spotify"
    open-on-workspace "music"
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE MANAGERS
// ═══════════════════════════════════════════════════════════════════════════════

// Thunar - Workspace 9 (Files)
window-rule {
    match app-id="thunar"
    open-on-workspace "files"
}

// Dolphin
window-rule {
    match app-id="dolphin"
    open-on-workspace "files"
}

// ═══════════════════════════════════════════════════════════════════════════════
// TERMINAL
// ═══════════════════════════════════════════════════════════════════════════════

// Ghostty - Workspace 2 (Terminal/Dev)
window-rule {
    match app-id="ghostty"
    open-on-workspace "terminal"
}

// Kitty
window-rule {
    match app-id="kitty"
    open-on-workspace "terminal"
}

// Alacritty
window-rule {
    match app-id="Alacritty"
    open-on-workspace "terminal"
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEVELOPMENT
// ═══════════════════════════════════════════════════════════════════════════════

// VS Code
window-rule {
    match app-id="code"
    open-on-workspace "terminal"
}

// Kate
window-rule {
    match app-id="kate"
    open-on-workspace "terminal"
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCREEN SHARING / SCREEN RECORDING
// ═══════════════════════════════════════════════════════════════════════════════

// Screen share dialogs
window-rule {
    match app-id="xdg-desktop-portal-wlr"
    open-floating true
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXCLUDED FROM SCREENSHOTS
// ═══════════════════════════════════════════════════════════════════════════════

