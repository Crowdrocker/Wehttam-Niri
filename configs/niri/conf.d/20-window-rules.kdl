    match app-id="krita"
    open-on-workspace "photography"
}

// Inkscape
window-rule {
    match app-id="inkscape"
    open-on-workspace "photography"
}

// DigiKam
window-rule {
    match app-id="digikam"
    open-on-workspace "photography"
