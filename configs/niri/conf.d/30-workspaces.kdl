// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── WORKSPACE 1: Browser ─────────────────────────────────────────────────────
workspace "browser" {
    name "Browser"
    open-workspace {
        // Default app for this workspace
    }
}

// ─── WORKSPACE 2: Terminal/Development ────────────────────────────────────────
workspace "terminal" {
    name "Terminal"
}

// ─── WORKSPACE 3: Gaming ──────────────────────────────────────────────────────
workspace "gaming" {
    name "Gaming"
}

// ─── WORKSPACE 4: Streaming/OBS ───────────────────────────────────────────────
workspace "streaming" {
    name "Streaming"
}

// ─── WORKSPACE 5: Photography ─────────────────────────────────────────────────
workspace "photography" {
    name "Photography"
}

// ─── WORKSPACE 6: Media/Video ─────────────────────────────────────────────────
workspace "media" {
    name "Media"
}

// ─── WORKSPACE 7: Communication ───────────────────────────────────────────────
workspace "communication" {
    name "Communication"
}

// ─── WORKSPACE 8: Music ───────────────────────────────────────────────────────
workspace "music" {
    name "Music"
}

// ─── WORKSPACE 9: Files ───────────────────────────────────────────────────────
workspace "files" {
    name "Files"
}

// ─── WORKSPACE 10: Misc ───────────────────────────────────────────────────────
workspace "misc" {
    name "Misc"
}

