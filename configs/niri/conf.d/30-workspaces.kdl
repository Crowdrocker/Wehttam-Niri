// ═══════════════════════════════════════════════════════════════════════════════
// WEHTTAMSNAPS NIRI - WORKSPACES CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════
// 10 organized workspaces for Photography, Gaming, and Content Creation
// Author: Matthew (WehttamSnaps)
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── WORKSPACE 1: Browser ─────────────────────────────────────────────────────
workspace "Browser" { open-on-output "DP-2"; }  // Browser

// ─── WORKSPACE 2: Terminal/Development ────────────────────────────────────────
workspace "Term" { open-on-output "DP-2"; }  // Terminal / Development

// ─── WORKSPACE 3: Gaming ──────────────────────────────────────────────────────
workspace "Gaming" { open-on-output "DP-2"; }  // Gaming

// ─── WORKSPACE 4: Streaming/OBS ───────────────────────────────────────────────
workspace "Stream" { open-on-output "DP-2"; }  // Streaming / OBS

// ─── WORKSPACE 5: Photography ─────────────────────────────────────────────────
workspace "Photo" { open-on-output "DP-2"; }  // Photography / GIMP / Darktable

// ─── WORKSPACE 6: Media/Video ─────────────────────────────────────────────────
workspace "Media" { open-on-output "DP-2"; }  // Media / Video Editing

// ─── WORKSPACE 7: Communication ───────────────────────────────────────────────
workspace "Comm" { open-on-output "DP-2"; }  // Communication / Discord

// ─── WORKSPACE 8: Music ───────────────────────────────────────────────────────
workspace "Music" { open-on-output "DP-2"; }  // Music / Audio Production

// ─── WORKSPACE 9: Files ───────────────────────────────────────────────────────
workspace "Files" { open-on-output "DP-2"; }  // File Management

// ─── WORKSPACE 10: Misc ───────────────────────────────────────────────────────
workspace "Misc" { open-on-output "DP-2"; } // Misc / Overflow


// ═══════════════════════════════════════════════════════════════════════════════
//  WORKSPACE ASSIGN
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// BROWSERS
// ═══════════════════════════════════════════════════════════════════════════════

// Firefox - Workspace 1 (Browser)
window-rule {
    match app-id="^brave-browser$"
    match app-id="^firefox$"
    match app-id="^Vivaldi-stable$"
    match app-id="^chromium$"
    match app-id="^zen-alpha$"
    match app-id="^google-chrome$"
    open-maximized true
    open-on-workspace "Browser"
}

// ═══════════════════════════════════════════════════════════════════════════════
// GAMING
// ═══════════════════════════════════════════════════════════════════════════════

// Steam - Workspace 3 (Gaming)
window-rule {
    match app-id="steam"
    open-maximized true
    open-on-workspace "Gaming"
}
// Lutris
window-rule {
    match app-id="lutris"
    open-on-workspace "Gaming"
}

// Heroic Games Launcher
window-rule {
    match app-id="heroic"
    open-on-workspace "Gaming"
}

window-rule {
    match title="Cyberpunk 2077"
    open-fullscreen true
    open-on-workspace "Gaming"
}

window-rule {
    match title="Fallout4"
    open-fullscreen true
    open-on-workspace "Gaming"
}

window-rule {
    match title="The Division 2"
    open-fullscreen true
    open-on-workspace "Gaming"
}

// ─── Game launchers ───
window-rule {
    match app-id="battle.net.exe"
    open-on-workspace "Gaming"
}

window-rule {
    match app-id="UbisoftConnect.exe"
    open-on-workspace "Gaming"
}
// ─────────────────── MODDING TOOLS - Floating Windows ───────────────────────

window-rule {
    match title="Vortex"
    match title="Mod Organizer"
    match title="Mod Organizer 2"
    match title="Wabbajack"
    match app-id="^com.nexusmods"
    match title="Special Offers"
    match title="Friends List"
    match title="Steam Settings"
    open-floating true
    open-on-workspace "Gaming"
}

window-rule {
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
}

// ═══════════════════════════════════════════════════════════════════════════════
// STREAMING / OBS
// ═══════════════════════════════════════════════════════════════════════════════

// OBS Studio - Workspace 4 (Streaming)
window-rule {
    match app-id=r#"^com\.obsproject\.Studio$"#
    min-width 876
    open-maximized true
    open-on-workspace "Stream"
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHOTOGRAPHY
// ═══════════════════════════════════════════════════════════════════════════════

// GIMP - Workspace 5 (Photography)
window-rule {
    match app-id="gimp"
    open-maximized true
    open-on-workspace "Photo"
}

window-rule {
    match app-id="gimp-2.10"
    open-maximized true
    open-on-workspace "Photo"
}

// Darktable
window-rule {
    match app-id="darktable"
    open-maximized true
    open-on-workspace "Photo"
}

// Krita
window-rule {
    match app-id="krita"
    open-maximized true
    open-on-workspace "Photo"
}

// Inkscape
window-rule {
    match app-id="inkscape"
    open-maximized true
    open-on-workspace "Photo"
}

// DigiKam
window-rule {
    match app-id="digikam"
    open-maximized true
    open-on-workspace "Photo"
}

// RawTherapee
window-rule {
    match app-id="rawtherapee"
    open-maximized true
    open-on-workspace "Photo"
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO EDITING
// ═══════════════════════════════════════════════════════════════════════════════

// DaVinci Resolve
window-rule {
    match app-id="resolve"
    open-maximized true
    open-on-workspace "Media"
}

// Kdenlive
window-rule {
    match app-id="kdenlive"
    open-maximized true
    open-on-workspace "Media"
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMMUNICATION
// ═══════════════════════════════════════════════════════════════════════════════

// Discord - Workspace 7 (Communication)
window-rule {
    match app-id="discord"
    open-on-workspace "Comm"
}

// Telegram
window-rule {
    match app-id="telegramdesktop"
    open-on-workspace "Comm"
}

// Slack
window-rule {
    match app-id="slack"
    open-on-workspace "Comm"
}

// ═══════════════════════════════════════════════════════════════════════════════
// MUSIC
// ═══════════════════════════════════════════════════════════════════════════════

// Spotify - Workspace 8 (Music)
window-rule {
    match app-id="spotify"
    open-maximized true
    open-on-workspace "Music"
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE MANAGERS
// ═══════════════════════════════════════════════════════════════════════════════

// Thunar - Workspace 9 (Files)
window-rule {
    match app-id="thunar"
    open-on-workspace "Files"
}

// Dolphin
window-rule {
    match app-id="dolphin"
    open-on-workspace "Files"
}
// ═══════════════════════════════════════════════════════════════════════════════
// DEVELOPMENT
// ═══════════════════════════════════════════════════════════════════════════════

// VS Code
window-rule {
    match app-id="code"
    open-maximized true
    open-on-workspace "Term"
}

// Kate
window-rule {
    match app-id="org.kde.kate"
    open-maximized true
    open-on-workspace "Term"
}
