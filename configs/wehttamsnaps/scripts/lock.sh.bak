#!/bin/bash
# Colors from your palette
CYAN="00ffff"
PURPLE="8a2be2"
PINK="ff5af1"

swaylock \
  --screenshots \
  --clock \
  --indicator \
  --indicator-radius 100 \
  --indicator-thickness 7 \
  --effect-blur 7x5 \
  --effect-vignette 0.5:0.5 \
  --ring-color $PURPLE \
  --key-hl-color $CYAN \
  --text-color $CYAN \
  --line-color 00000000 \
  --inside-color 00000088 \
  --separator-color 00000000 \
  --fade-in 0.2
