#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEHTTAMSNAPS J.A.R.V.I.S. PROTOCOL v3.1
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SOUND_BASE="/usr/share/wehttamsnaps/sounds"
STATE_FILE="$HOME/.cache/wehttamsnaps/sound-mode.state"
SILENT_FLAG="$HOME/.cache/wehttamsnaps/silent.active"

play_sound() {
    local name="$1"
    [[ -f "$SILENT_FLAG" ]] && return 0
    local mode=$(cat "$STATE_FILE" 2>/dev/null || echo "jarvis")

    # Try exact, then try with prefix, then fallback to jarvis folder
    if [[ -f "$SOUND_BASE/$mode/$name.mp3" ]]; then
        paplay "$SOUND_BASE/$mode/$name.mp3" &
    elif [[ -f "$SOUND_BASE/$mode/jarvis-$name.mp3" ]]; then
        paplay "$SOUND_BASE/$mode/jarvis-$name.mp3" &
    elif [[ -f "$SOUND_BASE/jarvis/$name.mp3" ]]; then
        paplay "$SOUND_BASE/jarvis/$name.mp3" &
    elif [[ -f "$SOUND_BASE/jarvis/jarvis-$name.mp3" ]]; then
        paplay "$SOUND_BASE/jarvis/jarvis-$name.mp3" &
    fi
}

case "$1" in
    # Utility Commands
    preview)        play_sound "$2" ;;
    list|ls)        ls "$SOUND_BASE/jarvis" | sed 's/\.mp3//' ;;
    status)         cat "$STATE_FILE" 2>/dev/null || echo "jarvis" ;;

    # Core Protocols
    startup)        play_sound "jarvis-startup" ;;
    reload)         play_sound "jarvis-reload" ;;
    lock)           play_sound "jarvis-lock" ;;

    # App Launchers (Add any others you need here)
    launch-brave)   play_sound "jarvis-launch-brave" ;;
    open-terminal)  play_sound "jarvis-open-terminal" ;;

    # Fallback for direct file playing
    *)
        if [[ -n "$1" ]]; then
            play_sound "$1"
        else
            echo "Usage: jarvis [command|filename]"
        fi
        ;;
esac
